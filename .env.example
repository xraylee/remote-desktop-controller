# RDCS Development Environment Variables
# Copy to .env and customize for your environment

# PostgreSQL
POSTGRES_PASSWORD=rdcs_dev_password
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=rdcs_redis_dev
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_USER=rdcs_minio
MINIO_PASSWORD=rdcs_minio_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API Server
API_PORT=8080
API_HOST=0.0.0.0

# Signaling Server
SIGNAL_PORT=8443

# Web Admin
WEB_PORT=5173
