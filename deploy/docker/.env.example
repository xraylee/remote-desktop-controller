# RDCS 开发环境配置
# 复制到 .env 并根据需要修改

# ============================================
# 服务端口配置
# ============================================
SIGNALING_PORT=8443
RELAY_STUN_PORT=3478
API_PORT=8080
WEB_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# 数据库配置
# ============================================
POSTGRES_PASSWORD=rdcs_dev
DB_HOST=localhost
DB_PORT=5432
DB_USER=rdcs
DB_NAME=rdcs

# ============================================
# Redis 配置
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# MinIO 配置（文件存储）
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_ENDPOINT=localhost:9000

# ============================================
# 日志级别
# ============================================
RUST_LOG=info
LOG_LEVEL=info

# ============================================
# JWT 密钥（开发环境）
# 生产环境请使用: openssl rand -base64 32
# ============================================
JWT_SECRET=dev_secret_please_change_in_production

# ============================================
# TOTP 配置（两步验证）
# ============================================
TOTP_ISSUER=RDCS
SKIP_TOTP=true

# ============================================
# CORS 配置
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
