# RDCS Signaling Server - Development Dockerfile (cargo-watch hot-reload)
# Build context: project root
# Build: docker build -f deploy/docker/Dockerfile.signaling.dev -t rdcs-signaling-dev .

FROM rust:1.86-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake \
    pkg-config \
    libssl-dev \
    netcat-openbsd \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install cargo-watch from precompiled binary to avoid edition2024 issues
RUN curl -L https://github.com/watchexec/cargo-watch/releases/download/v8.5.2/cargo-watch-v8.5.2-x86_64-unknown-linux-musl.tar.xz \
    | tar -xJ -C /tmp && \
    mv /tmp/cargo-watch-v8.5.2-x86_64-unknown-linux-musl/cargo-watch /usr/local/bin/ && \
    chmod +x /usr/local/bin/cargo-watch && \
    rm -rf /tmp/cargo-watch-*

WORKDIR /app

# Copy all source code (needed for dependency resolution in workspace)
COPY Cargo.toml Cargo.lock ./
COPY crates/ ./crates/

ENV RUST_LOG=debug

EXPOSE 8443

CMD ["cargo", "watch", "-x", "run -p rdcs-signaling", "-w", "crates"]
