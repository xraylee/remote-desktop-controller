# RDCS Management API - Development Dockerfile (air hot-reload)
# Build: docker build -f deploy/docker/Dockerfile.api.dev -t rdcs-api-dev .

FROM golang:1.25-alpine

RUN apk add --no-cache git gcc musl-dev

# Install air for hot-reload (pin to compatible version)
RUN go install github.com/air-verse/air@v1.61.0

WORKDIR /app

# Cache module downloads
COPY services/api/go.mod services/api/go.sum ./
RUN go mod download

# Copy source (will be overridden by volume mount in dev)
COPY services/api/ ./

EXPOSE 8080

CMD ["air", "-c", ".air.toml"]
