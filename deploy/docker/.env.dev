# RDCS - Development Environment Variables
# Usage: docker compose -f docker-compose.yml -f docker-compose.dev.yml --env-file .env.dev up -d

# Logging
RUST_LOG=debug
LOG_LEVEL=debug

# Security (disabled for local development)
SKIP_TLS=true
SKIP_TOTP=true

# Database
POSTGRES_DB=rdcs
POSTGRES_USER=rdcs
POSTGRES_PASSWORD=rdcs_dev
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Service ports (exposed to host for local development)
SIGNALING_PORT=8443
RELAY_STUN_PORT=3478
API_PORT=8080
WEB_PORT=3000
REDIS_PORT=6379

# Web console
VITE_API_BASE_URL=http://localhost:8080
