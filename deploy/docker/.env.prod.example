# RDCS - Production Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.prod.example .env && vim .env

# Domain for Caddy reverse proxy (required)
# Caddy will obtain TLS certificates for: signal.DOMAIN, api.DOMAIN, admin.DOMAIN
DOMAIN=example.com

# Caddy Let's Encrypt account email (required for certificate issuance)
CADDY_EMAIL=admin@example.com

# PostgreSQL password (required - use a strong random password)
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# MinIO root credentials (required - use a strong random password)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# MinIO Console port (optional, default: 9001)
MINIO_CONSOLE_PORT=9001
